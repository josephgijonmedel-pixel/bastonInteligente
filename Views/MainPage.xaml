<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BastonInteligente.Views.MainPage"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <Label Text="BASTÓN INTELIGENTE" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   TextColor="#2196F3"
                   Margin="0,10,0,0"/>

            <Frame CornerRadius="15" Padding="20" BackgroundColor="#F8F9FA" HasShadow="True">
                <VerticalStackLayout Spacing="15">

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="Batería: 85%" 
                               FontSize="16" 
                               TextColor="Black" 
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                        <ProgressBar Progress="0.85" ProgressColor="#2E7D32" WidthRequest="100" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <BoxView Color="{Binding ColorEstado}" WidthRequest="12" HeightRequest="12" CornerRadius="6" VerticalOptions="Center"/>
                        <Label Text="Sistema Activo" 
                               FontSize="15" 
                               TextColor="Black"
                               FontAttributes="Italic" 
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <BoxView Color="#D1D1D1" HeightRequest="1" HorizontalOptions="Fill" />

                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="ESTADO DEL SENSOR" FontSize="12" HorizontalOptions="Center" TextColor="Black" />
                        <Label Text="CONECTADO" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{Binding ColorEstado}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Spacing="5" Margin="0,20">
                <Label Text="Alertas detectadas" 
                       HorizontalOptions="Center" 
                       FontSize="18" 
                       TextColor="Black" />

                <Label Text="{Binding DistanciaLabel}" 
                       FontSize="100" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="{Binding ColorEstado}" />
            </VerticalStackLayout>

            <Button Text="SISTEMA MONITOREANDO" 
                    CornerRadius="25"
                    BackgroundColor="{Binding ColorEstado}" 
                    TextColor="White" 
                    HeightRequest="60" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>